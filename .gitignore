# Dependencies
node_modules/
package-lock.json
pnpm-lock.yaml
yarn.lock

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment (exclude all except .env.example)
.env*
!.env.example
.env.backup
.setup-last-session

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*

# Data
data/
*.db
*.sqlite

# Secrets
*.pem
*.key
*-key.json
service-account*.json

# Personal setup answers (keep base SETUP-ANSWERS.txt tracked)
SETUP-ANSWERS-*.txt

# Docker
docker-compose.override.yml

# Temp
tmp/
temp/
*.tmp

# Workspace (agent sandboxes)
workspace/
!workspace/.gitkeep

# Runtime storage (root level only, not shared/tools/src/storage)
# Keep structure files, ignore all persona-specific content
/storage/
!/storage/.gitkeep
!/storage/workspace-default/
!/storage/workspace-default/.gitkeep
!/storage/files-default/
!/storage/files-default/.gitkeep

# Per-persona storage directories (identity, memory, workspace, files)
/storage/*/identity.md
/storage/*/memory.md
/storage/*/workspace/
/storage/*/files/

# PM2 ecosystem files (contain secrets)
.pm2-nimble-*.json

# Claude Code local settings
.claude/

# Additional tools (allow structure/docs, ignore user folders)
additional-tools/*
!additional-tools/README.md
!additional-tools/tsconfig.json
!additional-tools/.gitkeep
!additional-tools/example/
# Ignore compiled files in example
additional-tools/example/*.js
additional-tools/example/*.js.map
additional-tools/example/*.d.ts
additional-tools/example/*.d.ts.map

# Tool export files (generated)
nimbleco-tools-export.json
